{
  "compilerOptions": {
    "module": "ESNext",                 // Modern standard for bundlers
    "moduleResolution": "bundler",      // The replacement for "node" (node10)
    "target": "ES2023",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false, // Set to true only if noEmit is true
    "resolvePackageJsonExports": true,   // Now valid with "bundler"
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "strictPropertyInitialization": false,
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "paths": {
      "@app/*": ["./apps/*"],
      "@auth": ["./libs/auth/src/index"], 
      "@auth/*": ["./libs/auth/src/*"],
      "@database": ["./libs/database/src/index"],
      "@database/*": ["./libs/database/src/*"],
      "@common": ["./libs/common/src/index"],
      "@common/*": ["./libs/common/src/*"],
      "@utils": ["./libs/common/src/utils/index"],
      "@utils/*": ["./libs/common/src/utils/*"]
    }
  }
}