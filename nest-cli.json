{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/core-service/src",
  "monorepo": true,
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "tsconfig.json"
  },
  "projects": {
    "core-service": {
      "type": "application",
      "root": "apps/core-service",
      "entryFile": "main",
      "sourceRoot": "apps/core-service/src",
      "compilerOptions": {
        "webpack": true,
        "webpackConfigPath": "webpack.config.js",
        "tsConfigPath": "apps/core-service/tsconfig.app.json",
        "assets": [
          {
            "include": "../../_env/core.env",
            "outDir": "dist/apps/core-service",
            "watchMode": true
          }
        ]
      }
    },
    "portal-service": {
      "type": "application",
      "root": "apps/portal-service",
      "entryFile": "main",
      "sourceRoot": "apps/portal-service/src",
      "compilerOptions": {
        "webpack": true,
        "webpackConfigPath": "webpack.config.js",
        "tsConfigPath": "apps/portal-service/tsconfig.app.json",
        "assets": [
          {
            "include": "../../_env/portal.env",
            "outDir": "dist/apps/portal-service",
            "watchMode": true
          }
        ]
      }
    },
    "worker-service": {
      "type": "application",
      "root": "apps/worker-service",
      "entryFile": "main",
      "sourceRoot": "apps/worker-service/src",
      "compilerOptions": {
        "webpack": true,
        "webpackConfigPath": "webpack.config.js",
        "tsConfigPath": "apps/worker-service/tsconfig.app.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "auth": {
      "type": "library",
      "root": "libs/auth",
      "entryFile": "index",
      "sourceRoot": "libs/auth/src",
      "compilerOptions": {
        "tsConfigPath": "libs/auth/tsconfig.lib.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    }
  }
}